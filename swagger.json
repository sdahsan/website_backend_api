{
  "openapi": "3.0.3",
  "info": {
    "title": "Syed's AI Assistant Portfolio Chatbot Platform API",
    "description": "Core orchestration and intelligence hub for Syed Azharuddin's portfolio chatbot platform ('Syed\\'s AI Assistant'). Manages session token quotas, database synchronization via direct Supabase REST queries, and Slack-integrated lockout resets. Designed for serverless deployment on GCP Cloud Run.",
    "version": "1.2.0",
    "contact": {
      "name": "Syed Azharuddin",
      "email": "syed.azharuddin@example.com"
    }
  },
  "servers": [
    {
      "url": "/",
      "description": "Dynamic Base URL"
    }
  ],
  "paths": {
    "/api/chat": {
      "post": {
        "summary": "Interact with Syed's AI Assistant",
        "description": "Process a conversation turn with Syed's AI Assistant. Enforces a 500-token budget check. If the threshold is exceeded, triggers a lockout requiring admin reset.",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "message"
                ],
                "properties": {
                  "sessionId": {
                    "type": "string",
                    "format": "uuid",
                    "description": "Unique session identifier. If null or omitted, a new UUID session token is dynamically generated and returned.",
                    "example": "4a7b5d2c-8f9e-4c1d-8b0a-9d8e7f6c5b4a"
                  },
                  "message": {
                    "type": "string",
                    "description": "The incoming textual chat message/query from the user.",
                    "example": "What is your experience with Kubernetes?"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Chat turn completed. Returns the AI reply OR triggers a token lockout response if quota is exceeded.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "sessionId": {
                      "type": "string",
                      "format": "uuid",
                      "description": "The active validated or newly generated session UUID tracking key.",
                      "example": "4a7b5d2c-8f9e-4c1d-8b0a-9d8e7f6c5b4a"
                    },
                    "requiresAuthForm": {
                      "type": "boolean",
                      "description": "Indicates whether the user has exceeded their token quota and must submit their contact details for administrative review.",
                      "example": false
                    },
                    "reply": {
                      "type": "string",
                      "description": "The rich markdown conversational text output generated by the underlying Gemini model. Only returned when requiresAuthForm is false.",
                      "example": "I have over 12 years of experience. On Google Cloud, I run high-throughput Kubernetes Engine (GKE) clusters and Serverless Cloud Run services."
                    },
                    "message": {
                      "type": "string",
                      "description": "Lockout status notification. Only returned when requiresAuthForm is true.",
                      "example": "Token quota constraint reached."
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error or downstream API disconnect.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "The infrastructure failed to validate processing constraints."
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/submit-auth": {
      "post": {
        "summary": "Submit Visitor Contact Data on Lockout",
        "description": "Triggered when a user encounters a token lockout. Ingests visitor identity, updates Supabase tracking, and streams a notification alert to team Slack channels asynchronously.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "sessionId",
                  "name",
                  "email"
                ],
                "properties": {
                  "sessionId": {
                    "type": "string",
                    "format": "uuid",
                    "description": "The target session UUID tracking key experiencing the lockout.",
                    "example": "4a7b5d2c-8f9e-4c1d-8b0a-9d8e7f6c5b4a"
                  },
                  "name": {
                    "type": "string",
                    "description": "Visitor's full name.",
                    "example": "Jane Doe"
                  },
                  "email": {
                    "type": "string",
                    "format": "email",
                    "description": "Visitor's contact email address.",
                    "example": "jane.doe@example.com"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authorization logged successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "message": {
                      "type": "string",
                      "example": "Authorization logged."
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "The infrastructure failed to validate processing constraints."
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/slack-webhook-approval": {
      "post": {
        "summary": "Administrative Session Override",
        "description": "Secured route utilized by administrators to reset a visitor's token consumption, approve their session, and resume the normal chat cycle.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "secretToken",
                  "targetSessionId"
                ],
                "properties": {
                  "secretToken": {
                    "type": "string",
                    "description": "Security administrative credential passphrase matching process.env.INTERNAL_SECRET_PASSPHRASE.",
                    "example": "my-secret-admin-passphrase-here"
                  },
                  "targetSessionId": {
                    "type": "string",
                    "format": "uuid",
                    "description": "The session UUID tracking key to reset and approve.",
                    "example": "4a7b5d2c-8f9e-4c1d-8b0a-9d8e7f6c5b4a"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Session successfully unlocked and reset.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "message": {
                      "type": "string",
                      "example": "Session successfully reset."
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized. Invalid administrative secretToken credentials.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "Unauthorized: Invalid administrative credentials."
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "The infrastructure failed to validate processing constraints."
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/slack-interaction": {
      "post": {
        "summary": "Slack Interaction Callback Router",
        "description": "Triggered automatically by Slack's interactive servers when an administrator clicks the 'Approve Session' primary button inside a team channel lockout alert.",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "payload"
                ],
                "properties": {
                  "payload": {
                    "type": "string",
                    "description": "JSON string sent from Slack representing the action, visitor metadata, and button value containing the target sessionId.",
                    "example": "{\"actions\":[{\"action_id\":\"approve_session\",\"value\":\"4a7b5d2c-8f9e-4c1d-8b0a-9d8e7f6c5b4a\"}]}"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Slack interaction parsed successfully and session reset.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "text": {
                      "type": "string",
                      "example": "✅ *Session `4a7b5d2c-8f9e-4c1d-8b0a-9d8e7f6c5b4a` has been successfully reset and approved by Admin.*"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request. Missing or invalid payload data."
          },
          "500": {
            "description": "Internal Server Error."
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "APIKey",
        "description": "API Gateway authentication. Set process.env.API_GATEWAY_KEY on the backend, and supply the same key in the header as 'Authorization: Bearer <API_GATEWAY_KEY>'."
      }
    }
  }
}
